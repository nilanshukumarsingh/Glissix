{
  "name": "glissix",
  "version": "0.1.0",
  "description": "An inertia-driven physics engine for tactile UI motion.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "author": "Nilanshu Kumar Singh <nilanshukumarsingh2005@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nilanshukumarsingh/Glissade.git"
  },
  "bugs": {
    "url": "https://github.com/nilanshukumarsingh/Glissade/issues"
  },
  "homepage": "https://github.com/nilanshukumarsingh/Glissade#readme",
  "keywords": [
    "physics",
    "physics-engine",
    "animation",
    "motion",
    "tactile-ui",
    "inertia",
    "spring-physics",
    "spring",
    "ui-motion",
    "inertia-driven",
    "tactile"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run --pool threads",
    "test:watch": "vitest --pool threads"
  }
}
